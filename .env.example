# ============================================================
# MasterStudio Hotel - Ortam Değişkenleri (.env dosyası)
# ============================================================
#
# Kurulum Adımları:
# 1. Bu dosyayı kopyala: cp .env.example .env
# 2. .env dosyasını düzenle ve kendi değerlerini ekle
# 3. .env dosyasını asla git'e commit etmeyin!
#
# ============================================================

# ============================================================
# VERİTABANI AYARLARI
# ============================================================

# MySQL Sunucusu (Local: localhost, Docker: mysql)
DB_HOST=localhost

# Veritabanı Adı
DB_NAME=masterstudio_hotel

# Veritabanı Kullanıcısı
DB_USER=hotel_user

# Veritabanı Şifresi (güçlü şifre kullanın!)
DB_PASS=your_secure_password_here

# MySQL Root Şifresi (Docker/kurulum için)
MYSQL_ROOT_PASSWORD=your_root_password_here

# ============================================================
# ORTAM MODU
# ============================================================

# development = Detaylı hata mesajları
# production = Hataları log'a yaz
PHP_ENV=development

# ============================================================
# SİTE AYARLARI
# ============================================================

SITE_URL=http://localhost

# ============================================================
# DOCKER PORT AYARLARI
# ============================================================

APP_PORT=80
MYSQL_PORT=3306
PMA_PORT=8080

# ============================================================
# GÜVENLİK
# ============================================================

# Session Timeout (saniye - varsayılan: 3600 = 1 saat)
SESSION_TIMEOUT=3600

# ============================================================
# EMAIL AYARLARI (opsiyonel)
# ============================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@example.com

# ============================================================
# KURULUM NOTLARI
# ============================================================
#
# HIZLI KURULUM:
#   Web Installer: install.php'yi tarayıcıdan açın
#   VPS/cPanel:    chmod +x install.sh && sudo ./install.sh
#   Docker:        docker compose up -d
#
# PRODUCTION İÇİN:
#   - PHP_ENV=production yapın
#   - Güçlü şifreler kullanın
#   - SSL sertifikası kurun
#   - install.php ve install.sh dosyalarını silin
#
# ============================================================

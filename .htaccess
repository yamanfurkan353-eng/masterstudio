# Hassas dosyalara erişimi engelle
<FilesMatch "^\.env|\.git">
    Require all denied
</FilesMatch>

<FilesMatch "\.(sql|log|ini|bak|tmp)$">
    Require all denied
</FilesMatch>

# Dizin listelemeyi kapat
Options -Indexes

# PHP hata mesajlarını gizle (production)
php_flag display_errors off
php_flag log_errors on
